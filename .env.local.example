# ============================================================
# VoidZero CPA — Environment Variables
# Copy this to .env.local and fill in real values.
# .env.local is gitignored — NEVER commit real credentials.
# ============================================================

# ── Razorpay (Payment Processing) ──────────────────────────
# Get these from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── MongoDB (Database) ─────────────────────────────────────
# Connection string from MongoDB Atlas (Network Access must allow Vercel IPs)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/

# ── Email (Resend) ──────────────────────────────────────────
# API key: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Must be a verified sender domain in Resend (e.g. onboarding@cpahustler.com)
RESEND_FROM_EMAIL=onboarding@cpahustler.com

# ── Telegram (Notifications) ────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCDEFGHIJKLMNabcdefghijklmnopqrstuvwxyz
# Chat ID of the channel/group to receive notifications
TELEGRAM_CHAT_ID=-1001234567890
# Optional: message thread ID for threaded groups
TELEGRAM_MESSAGE_THREAD_ID=

# ── Business Config ────────────────────────────────────────
# Consultation price in paisa (INR) — 49900 = ₹499
# Can be overridden per-order in razorpay-webhook if needed
CONSULTATION_AMOUNT=49900

# ── Shared Community Links ─────────────────────────────────
# SECURITY: These are now read from env vars instead of hardcoded.
# Update these to change WhatsApp/Telegram links across all routes at once
# without touching source code.
WHATSAPP_LINK=https://chat.whatsapp.com/GG6eC15vtOq9LDQen79Kj1

# ── Analytics (Client-Side, Public) ────────────────────────
# These are safe to expose to the browser (prefixed NEXT_PUBLIC_)
# Microsoft Clarity — analytics
NEXT_PUBLIC_CLARITY_ID=xxxxxxxxxx
# Razorpay public key — frontend uses this to initialize the payment widget
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
